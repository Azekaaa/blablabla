# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# Bitrix24
BITRIX_WEBHOOK=https://your-domain.bitrix24.ru/rest/1/your_webhook_token/

# Database
DB_URL=postgresql+asyncpg://user:password@localhost:5432/crm_bot
# For SQLite (MVP): DB_URL=sqlite+aiosqlite:///./crm_bot.db

# Scheduler times (24h format, UTC)
REPORT_TIME_MORNING=09:00
REPORT_TIME_EVENING=18:00

# Analysis thresholds
INACTIVE_DAYS_THRESHOLD=3
STUCK_STAGE_DAYS_THRESHOLD=7

# Logging
LOG_LEVEL=INFO
